// Build ordered section list + question groups from QUESTIONS (preserves file order)
const SECTION_ORDER = [];
const BY_SECTION = {};
QUESTIONS.forEach(q => {
  if(!BY_SECTION[q.section]){ BY_SECTION[q.section] = []; SECTION_ORDER.push(q.section); }
  BY_SECTION[q.section].push(q);
});

function unitRangeLabel(section){
  if(section === "Vocabulary Challenge") return "Qo'shimcha";
  const units = BY_SECTION[section].map(q => q.unit);
  const min = Math.min(...units), max = Math.max(...units);
  return min === max ? ("Unit " + min) : ("Unit " + min + "–" + max);
}

// ---------------- App State ----------------
let state = {
  screen: "home",       // home | quiz | sectionResult | finalResult
  mode: null,            // "full" | "section" | "review"
  queue: [],             // ordered question objects for this run
  qIndex: 0,
  selected: null,        // selected option index for current question
  answered: false,
  runAnswers: {},        // id -> {selectedIndex, correct}  (this run only)
  allAnswers: {},         // id -> {selectedIndex, correct}  (persists across whole session, for dashboard)
  currentSectionName: null,
  sectionStartIdxInFull: 0
};

function startRun(mode, questions, sectionName){
  state.mode = mode;
  state.queue = questions;
  state.qIndex = 0;
  state.selected = null;
  state.answered = false;
  state.runAnswers = {};
  state.currentSectionName = sectionName || (questions[0] ? questions[0].section : null);
  state.screen = "quiz";
  render();
  window.scrollTo({top:0, behavior:"smooth"});
}

function startFullTest(){
  startRun("full", QUESTIONS.slice());
}

function startSection(sectionName){
  startRun("section", BY_SECTION[sectionName].slice(), sectionName);
}

function startReviewMistakes(){
  const missedIds = Object.keys(state.allAnswers).filter(id => !state.allAnswers[id].correct);
  const qs = QUESTIONS.filter(q => missedIds.includes(q.id));
  if(qs.length === 0) return;
  startRun("review", qs);
}

function selectOption(idx){
  if(state.answered) return;
  const q = state.queue[state.qIndex];
  const correct = idx === q.correct;
  state.selected = idx;
  state.answered = true;
  state.runAnswers[q.id] = {selectedIndex: idx, correct};
  state.allAnswers[q.id] = {selectedIndex: idx, correct};
  render();
}

function nextQuestion(){
  const isLastInQueue = state.qIndex >= state.queue.length - 1;
  const currentSection = state.queue[state.qIndex].section;
  const nextSectionName = !isLastInQueue ? state.queue[state.qIndex+1].section : null;

  if(!isLastInQueue && nextSectionName === currentSection){
    state.qIndex++;
    state.selected = null;
    state.answered = false;
    render();
    window.scrollTo({top:0, behavior:"smooth"});
    return;
  }

  // Reached the end of the current section, or the end of the whole queue.
  // Always show a result screen for what was just completed; only "full"
  // mode with more sections remaining continues straight into the next one.
  state.screen = "sectionResult";
  state._pendingNextSection = (state.mode === "full" && !!nextSectionName && nextSectionName !== currentSection);
  render();
  window.scrollTo({top:0, behavior:"smooth"});
}

function continueAfterSectionResult(){
  if(state._pendingNextSection){
    state.qIndex++;
    state.selected = null;
    state.answered = false;
    state.currentSectionName = state.queue[state.qIndex].section;
    state.screen = "quiz";
  } else if(state.mode === "full"){
    // last section of the full run just finished -> show whole-book dashboard
    state.screen = "finalResult";
  } else {
    // a single section or a mistakes-review run just finished
    state.screen = "home";
  }
  render();
  window.scrollTo({top:0, behavior:"smooth"});
}

function retryRun(){
  startRun(state.mode, state.queue.slice(), state.currentSectionName);
}

function goHome(){
  state.screen = "home";
  render();
  window.scrollTo({top:0, behavior:"smooth"});
}

function scoreOf(ids, answerBag){
  let correct = 0;
  ids.forEach(id => { if(answerBag[id] && answerBag[id].correct) correct++; });
  return { correct, total: ids.length };
}

function pctClass(pct){
  if(pct >= 80) return "great";
  if(pct >= 50) return "ok";
  return "low";
}

function letterFor(i){ return ["A","B","C","D"][i]; }

// ---------------- Renderers ----------------
function render(){
  const app = document.getElementById("app");
  if(state.screen === "home") app.innerHTML = renderHome();
  else if(state.screen === "quiz") app.innerHTML = renderQuiz();
  else if(state.screen === "sectionResult") app.innerHTML = renderSectionResult();
  else if(state.screen === "finalResult") app.innerHTML = renderFinalResult();
  attachHandlers();
}

function overallStats(){
  const answeredIds = Object.keys(state.allAnswers);
  const total = QUESTIONS.length;
  const done = answeredIds.length;
  const correct = answeredIds.filter(id => state.allAnswers[id].correct).length;
  return {done, total, correct};
}

function renderHome(){
  const stats = overallStats();
  const hasProgress = stats.done > 0;

  const cards = SECTION_ORDER.map(sec => {
    const meta = SECTION_META[sec] || {uz: "", icon:"•"};
    const qs = BY_SECTION[sec];
    const ids = qs.map(q=>q.id);
    const answeredIds = ids.filter(id => state.allAnswers[id]);
    const {correct} = scoreOf(ids, state.allAnswers);
    const attempted = answeredIds.length;
    let pillHtml = "";
    if(attempted > 0){
      const pct = Math.round((correct/attempted)*100);
      pillHtml = '<span class="score-pill ' + pctClass(pct) + '">' + correct + '/' + attempted + '</span>';
    }
    const vocabCls = sec === "Vocabulary Challenge" ? " is-vocab" : "";
    return '<button class="section-card' + vocabCls + '" data-action="start-section" data-section="' + encodeURIComponent(sec) + '">' +
      '<span class="section-tag">' + unitRangeLabel(sec) + '</span>' +
      '<span class="section-card-body">' +
        '<p class="section-card-title">' + meta.uz + '</p>' +
        '<p class="section-card-sub">' + sec + '</p>' +
        '<span class="section-card-meta">' + qs.length + ' ta savol ' + pillHtml + '</span>' +
      '</span>' +
    '</button>';
  }).join("");

  const reviewCount = Object.keys(state.allAnswers).filter(id => !state.allAnswers[id].correct).length;

  return '' +
  '<div class="masthead">' +
    '<div class="masthead-brand"><span class="mark">E</span> Raymond Murphy — 5th Edition asosida</div>' +
    (hasProgress ? '<div class="masthead-score">Umumiy natija<br><b>' + stats.correct + '/' + stats.done + '</b> · ' + stats.done + '/' + stats.total + ' ishlangan</div>' : '') +
  '</div>' +

  '<div class="hero">' +
    '<div class="hero-eyebrow">To\'liq grammatika &amp; lug\'at testi</div>' +
    '<h1>145 unit, bitta test.</h1>' +
    '<p>Kitobning barcha 145 ta unitiga asoslangan savollar, shu jumladan qo\'shimcha lug\'at (prepositions, phrasal verbs) mashqlari. Har bir javobdan so\'ng izoh va tegishli unit raqami ko\'rsatiladi — xato qilsangiz, kitobning aynan qaysi sahifasini qayta o\'qish kerakligini bilib olasiz.</p>' +
    '<div class="hero-stats">' +
      '<div class="hero-stat"><b>' + QUESTIONS.length + '</b><span>Jami savollar</span></div>' +
      '<div class="hero-stat"><b>145</b><span>Grammatika uniti</span></div>' +
      '<div class="hero-stat"><b>' + SECTION_ORDER.length + '</b><span>Bo\'lim</span></div>' +
    '</div>' +
    '<div class="btn-row">' +
      '<button class="btn btn-primary" data-action="start-full">' + (hasProgress ? "Testni davom ettirish" : "To'liq testni boshlash") + ' →</button>' +
      (reviewCount > 0 ? '<button class="btn btn-ghost" data-action="review-mistakes">Xatolarni qayta ishlash (' + reviewCount + ')</button>' : '') +
    '</div>' +
  '</div>' +

  '<div class="section-list-label">Bo\'lim bo\'yicha mashq qilish</div>' +
  '<div class="card-grid">' + cards + '</div>' +

  '<footer class="note">Test "English Grammar in Use" (5th Edition, R. Murphy) kitobining tuzilishi asosida tayyorlandi.<br>Har bir savol kitobdagi tegishli Unit raqamiga bog\'langan.</footer>';
}

function renderQuiz(){
  const q = state.queue[state.qIndex];
  const totalInQueue = state.queue.length;
  const posInQueue = state.qIndex + 1;
  const pct = Math.round((posInQueue-1) / totalInQueue * 100);
  const meta = SECTION_META[q.section] || {uz:""};

  const optsHtml = q.options.map((opt, i) => {
    let cls = "option";
    let mark = "";
    if(state.answered){
      if(i === q.correct){ cls += " correct"; mark = "✓"; }
      else if(i === state.selected){ cls += " wrong"; mark = "✕"; }
      else { cls += " dim"; }
      cls += " locked";
    }
    return '<button class="' + cls + '" data-action="select" data-idx="' + i + '" ' + (state.answered ? "disabled" : "") + '>' +
      '<span class="letter">' + letterFor(i) + '</span>' +
      '<span>' + opt + '</span>' +
      (mark ? '<span class="mark">' + mark + '</span>' : '') +
    '</button>';
  }).join("");

  const modeLabel = state.mode === "full" ? "To'liq test" : state.mode === "review" ? "Xatolarni qaytarish" : meta.uz;

  return '' +
  '<div class="quiz-topbar">' +
    '<button class="back-btn" data-action="home">← Chiqish</button>' +
    '<div class="progress-track"><div class="progress-fill" style="width:' + pct + '%"></div></div>' +
    '<div class="progress-count">' + posInQueue + ' / ' + totalInQueue + '</div>' +
  '</div>' +

  '<div class="q-card">' +
    '<div class="q-unit-row">' +
      '<span class="q-unit-badge">Unit ' + q.unit + '</span>' +
      '<span class="q-unit-title">' + q.unitTitle + '<br><span style="color:var(--ink-faint)">' + modeLabel + '</span></span>' +
    '</div>' +
    '<p class="q-prompt">' + q.prompt.replace(/___/g, '<span class="blank">___</span>') + '</p>' +
    '<div class="options">' + optsHtml + '</div>' +
    (state.answered ? '<div class="explain"><b>' + (state.selected === q.correct ? "To'g'ri! " : "Izoh: ") + '</b>' + q.explanation + '</div>' : '') +
    '<div class="q-footer">' +
      (state.answered ? '<button class="btn btn-primary" data-action="next">' + (state.qIndex === state.queue.length - 1 ? "Yakunlash" : "Keyingi savol") + ' →</button>' : '') +
    '</div>' +
  '</div>';
}

function renderSectionResult(){
  const sectionName = state.currentSectionName;
  const sectionQs = state.mode === "full" ? BY_SECTION[sectionName] : state.queue;
  const ids = sectionQs.map(q=>q.id);
  const {correct, total} = scoreOf(ids, state.runAnswers);
  const pct = total ? Math.round((correct/total)*100) : 0;
  const missed = sectionQs.filter(q => state.runAnswers[q.id] && !state.runAnswers[q.id].correct);

  const missedHtml = missed.length ? (
    '<div class="review-list"><h3>Qayta ko\'rish tavsiya etiladi</h3>' +
    missed.map(q => '<span class="review-chip"><span class="num">' + q.unit + '</span>' + q.unitTitle + '</span>').join("") +
    '</div>'
  ) : '<p style="color:var(--green-deep);font-weight:600;margin-top:18px;">Ushbu bo\'limda barcha savollarga to\'g\'ri javob berdingiz! 🎉</p>';

  let heading, sub;
  if(state.mode === "review"){
    heading = "Xatolarni qaytarish";
    sub = "Oldin xato qilingan " + total + " ta savol bo'yicha natija";
  } else {
    const meta = SECTION_META[sectionName] || {uz:""};
    heading = meta.uz;
    sub = sectionName + " bo'limi bo'yicha natijangiz";
  }

  let primaryLabel, primaryAction;
  if(state.mode === "full" && state._pendingNextSection){
    primaryLabel = "Keyingi bo'lim →"; primaryAction = "continue-after-section";
  } else if(state.mode === "full"){
    primaryLabel = "Yakuniy natijani ko'rish →"; primaryAction = "continue-after-section";
  } else {
    primaryLabel = "Qayta urinish"; primaryAction = "retry-run";
  }

  return '' +
  '<div class="summary-card">' +
    '<div class="summary-ring" style="--pct:' + pct + '"><b>' + pct + '%</b><span>' + correct + '/' + total + '</span></div>' +
    '<h2>' + heading + '</h2>' +
    '<p class="lead">' + sub + '</p>' +
    missedHtml +
    '<div class="btn-row" style="justify-content:center;margin-top:22px;">' +
      '<button class="btn btn-primary" data-action="' + primaryAction + '">' + primaryLabel + '</button>' +
      '<button class="btn btn-secondary" data-action="home">Bosh sahifa</button>' +
    '</div>' +
  '</div>';
}

function renderFinalResult(){
  const stats = overallStats();
  const pct = stats.done ? Math.round((stats.correct/stats.done)*100) : 0;

  let msg;
  if(pct >= 90) msg = "Ajoyib! Kitobni chuqur o'zlashtirgansiz.";
  else if(pct >= 70) msg = "Yaxshi natija! Bir nechta unitni qayta ko'rib chiqsangiz, mukammal bo'ladi.";
  else if(pct >= 50) msg = "Yomon emas — lekin quyidagi unitlarni qayta o'qib chiqishni tavsiya qilamiz.";
  else msg = "Bu unitlarni kitobdan qayta o'qib, testni yana ishlab ko'ring.";

  const barsHtml = SECTION_ORDER.map(sec => {
    const qs = BY_SECTION[sec];
    const ids = qs.map(q=>q.id);
    const answeredIds = ids.filter(id => state.allAnswers[id]);
    if(answeredIds.length === 0) return "";
    const {correct} = scoreOf(ids, state.allAnswers);
    const pctSec = Math.round((correct/answeredIds.length)*100);
    const meta = SECTION_META[sec] || {uz:sec};
    return '<div class="mini-bar-row">' +
      '<span class="mini-bar-label"><b>' + meta.uz + '</b></span>' +
      '<span class="mini-bar-pct">' + correct + '/' + answeredIds.length + '</span>' +
      '<div class="mini-bar-track"><div class="mini-bar-fill" style="width:' + pctSec + '%; background:' + (pctSec>=80?'var(--green)':pctSec>=50?'var(--gold)':'var(--coral)') + '"></div></div>' +
    '</div>';
  }).join("");

  const missedIds = Object.keys(state.allAnswers).filter(id => !state.allAnswers[id].correct);
  const missedQs = QUESTIONS.filter(q => missedIds.includes(q.id)).sort((a,b)=>a.unit-b.unit);

  const missedDetailHtml = missedQs.length ? (
    '<div class="review-list" style="margin-top:26px;"><h3>Kitobda qayta o\'qish uchun unitlar (' + missedQs.length + ')</h3>' +
    missedQs.map(q => '<span class="review-chip"><span class="num">' + q.unit + '</span>' + q.unitTitle + '</span>').join("") +
    '</div>'
  ) : '';

  return '' +
  '<div class="summary-card">' +
    '<div class="summary-ring" style="--pct:' + pct + '"><b>' + pct + '%</b><span>' + stats.correct + '/' + stats.done + '</span></div>' +
    '<h2>Yakuniy natija</h2>' +
    '<p class="lead">' + msg + '</p>' +
    '<div class="mini-bars">' + barsHtml + '</div>' +
    missedDetailHtml +
    '<div class="btn-row" style="justify-content:center;margin-top:22px;">' +
      (missedQs.length ? '<button class="btn btn-primary" data-action="review-mistakes">Xato javoblarni qayta ishlash</button>' : '') +
      '<button class="btn btn-secondary" data-action="home">Bosh sahifa</button>' +
    '</div>' +
  '</div>';
}

// ---------------- Event delegation ----------------
function attachHandlers(){
  document.querySelectorAll("[data-action]").forEach(el => {
    el.onclick = (e) => {
      const action = el.getAttribute("data-action");
      if(action === "start-full") startFullTest();
      else if(action === "start-section") startSection(decodeURIComponent(el.getAttribute("data-section")));
      else if(action === "select") selectOption(parseInt(el.getAttribute("data-idx"),10));
      else if(action === "next") nextQuestion();
      else if(action === "continue-after-section") continueAfterSectionResult();
      else if(action === "retry-run") retryRun();
      else if(action === "home") goHome();
      else if(action === "review-mistakes") startReviewMistakes();
    };
  });
}

render();
</script>
</body>
</html>
